<!doctype html>
<html>
<style>
	html { 
		font-family: Arial, Helvetica, sans-serif 
	}
	table { 
  		border: 1px solid black;
  		border-collapse: collapse;
  		font-size: 18px;
  	}
  	td {  		
		text-align: left;
  		padding: 0.2em 0.5em;
  	}
	th {
  		background-color: #ffebe6;
  		color: #c32e04;
  		padding: 0.2em 0.5em;
		text-align: left;
	}
	tbody tr:nth-child(odd) { 
  		background-color: #e4ebf2; 
  		color: #000; 
	}
	
	tbody tr:hover, tfoot tr:hover { 
  background-color:#fffbf0;
}

tbody td:hover, tfoot td:hover { 
  background-color: #fce4a2; 
}
</style>
<head>
</head>
<body>
Hallo $name,
<p>
hier die aktuellen Salden, nach dem Spiel vom $datum
</p>
<p>
	<table border="1">
		<tr>
			<th>Name</th>
			<th>Saldo</th>
		</tr>
		#foreach( $entry in $saldo )

		<tr>
			<td align="left">$entry.name</td>
			<td align="right">$entry.betrag &euro;</td>
		</tr>
	#end
		<tr>
			<td colspan="2">
				Saldo: $completesaldo &euro;
			</td>
		</tr>
	</table>
</p>
<p>
	Buchungen f³r dieses Spiel:
</p>
<p>
	<table border="1">
		<tr>
			<th>
				Name
			</th>
			<th>
				Betrag
			</th>
		</tr>
		#foreach( $buchung in $buchungen )
		<tr>
			<td>
				$buchung.name
			</td>
			<td align="right">
				$buchung.betrag &euro;
			</td>
		</tr>
			#end
		
	</table>
</p>

<p>
Sch&ouml;ne Gr&uuml;&szlig;e
<br/>
Werner
</p>
<body>
</html>
