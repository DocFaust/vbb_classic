<?xml version="1.0" encoding="ISO-8859-1"?>
<persistence version="2.1"
	xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">
	<persistence-unit name="vbb">
		<provider>org.hibernate.ejb.HibernatePersistence</provider>
		<jta-data-source>java:/jdbc/vbb2</jta-data-source>
		<class>de.docfaust.vbb.data.entity.Buchung</class>
		<class>de.docfaust.vbb.data.entity.Config</class>
		<class>de.docfaust.vbb.data.entity.Season</class>
		<class>de.docfaust.vbb.data.entity.Spiel</class>
		<class>de.docfaust.vbb.data.entity.Spieler</class>
		<class>de.docfaust.vbb.data.entity.User</class>
		<class>de.docfaust.vbb.data.entity.Group</class>
		<class>de.docfaust.vbb.data.entity.Mail</class>
		<class>de.docfaust.vbb.data.entity.JournalEntry</class>
		<class>de.docfaust.vbb.data.entity.Token</class>
		<shared-cache-mode>NONE</shared-cache-mode>
		<properties>
<!-- Derby 
 			<property name="hibernate.dialect" value="org.hibernate.dialect.DerbyTenSevenDialect"/>
-->
 <!-- MySQL 
 -->
  			<property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
			<property name="hibernate.show_sql" value="true"/>
			<property name="hibernate.format_sql" value="true"/>
 		</properties>
	</persistence-unit>
</persistence>
